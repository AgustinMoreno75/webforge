# Desarrollo local WebForge

# App runtime
NODE_ENV=development
PORT=8080
APP_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
TRUST_PROXY=false

# Database and auth
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webforge?schema=public"
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=1092276043565-kkt0eh32fr5pmnmbh5qku1q1oatfa4tl.apps.googleusercontent.com
GOOGLE_ANALYTICS_ID=
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=agustinezequielmoreno@gmail.com
SMTP_PASS=your-smtp-app-password

# Mail routing
MAIL_FROM="WebForge <agustinezequielmoreno@gmail.com>"
CONTACT_TO_EMAIL=agustinezequielmoreno@gmail.com

# Anti-spam and network controls
BLOCKED_IPS=
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
VITE_RECAPTCHA_SITE_KEY=

# Background jobs
JOBS_ENABLED=true
JOBS_TIMEZONE=America/Argentina/Buenos_Aires
JOB_PLAN_LIFECYCLE=0 9 * * *

# Core account seed (si lo dejas vacio, el seed usa los defaults del codigo)
CORE_ACCOUNT_CEO_FULL_NAME=CEOWebForge
CORE_ACCOUNT_CEO_EMAIL=agustinezequielmoreno@gmail.com
CORE_ACCOUNT_CEO_PASSWORD=
CORE_ACCOUNT_CEO_PASSWORD_HASH=
