# Produccion WebForge con Zoho SMTP
# Ejecutar una sola vez antes del primer arranque estable:
# npm run db:migrate:deploy
# npm run db:seed

# App runtime
PORT=8080
APP_ORIGIN=https://getwebforge.com
APP_BASE_URL=https://getwebforge.com
TRUST_PROXY=true

# Database and auth
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/webforge?schema=public"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_LARGO_Y_RANDOM
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=1092276043565-kkt0eh32fr5pmnmbh5qku1q1oatfa4tl.apps.googleusercontent.com
GOOGLE_ANALYTICS_ID=G-0106CF2ZET
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# SMTP (Zoho)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hola@getwebforge.com
SMTP_PASS=REEMPLAZA_CON_TU_APP_PASSWORD_DE_ZOHO

# Mail routing
MAIL_FROM="WebForge <hola@getwebforge.com>"
CONTACT_TO_EMAIL=agustinezequielmoreno@gmail.com

# Anti-spam and network controls
BLOCKED_IPS=
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=REEMPLAZA_CON_TU_RECAPTCHA_SECRET
RECAPTCHA_MIN_SCORE=0.5
VITE_RECAPTCHA_SITE_KEY=REEMPLAZA_CON_TU_RECAPTCHA_SITE_KEY

# Background jobs
JOBS_ENABLED=true
JOBS_TIMEZONE=America/Argentina/Buenos_Aires
JOB_PLAN_LIFECYCLE=0 9 * * *

# Core account seed (solo se usa CEO)
CORE_ACCOUNT_CEO_FULL_NAME=CEOWebForge
CORE_ACCOUNT_CEO_EMAIL=agustinezequielmoreno@gmail.com
CORE_ACCOUNT_CEO_PASSWORD=CAMBIA_ESTA_PASSWORD
CORE_ACCOUNT_CEO_PASSWORD_HASH=
